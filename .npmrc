auto-install-peers=true
strict-peer-dependencies=false
# React Native + Metro bundler don't understand pnpm's isolated node_modules
# layout. `hoisted` linking flattens the tree so Expo/Metro can find modules.
node-linker=hoisted
# Expo's native module resolver walks the monorepo; make sure peer deps land
# in the same tree.
shamefully-hoist=true
