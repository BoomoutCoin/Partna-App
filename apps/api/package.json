{
  "name": "@partna/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --env-file=.env --import tsx/esm --watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "node --import tsx/esm --experimental-test-module-mocks --test src/**/*.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "9.0.1",
    "@fastify/helmet": "11.1.1",
    "@fastify/jwt": "8.0.1",
    "@fastify/rate-limit": "9.1.0",
    "@fastify/sensible": "5.6.0",
    "@partna/types": "workspace:*",
    "@supabase/supabase-js": "2.45.4",
    "fastify": "4.28.1",
    "fastify-plugin": "4.5.1",
    "pino": "9.4.0",
    "pino-pretty": "11.2.2",
    "stripe": "^22.0.1",
    "viem": "2.21.25",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "tsx": "4.19.1",
    "typescript": "5.5.4"
  }
}
