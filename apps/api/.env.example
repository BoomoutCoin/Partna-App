# Copy to .env and fill in. Never commit .env files.

NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# Supabase — from your project dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# JWT — generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-256-bit-random-string
JWT_EXPIRES_IN=7d

# Alchemy webhook HMAC (set in Alchemy Notify dashboard)
ALCHEMY_WEBHOOK_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# Expo push (optional — server-side sends)
EXPO_ACCESS_TOKEN=

# Optional: Redis for rate limiting in prod
REDIS_URL=

# Optional: separate admin JWT secret for dashboard routes
ADMIN_JWT_SECRET=
